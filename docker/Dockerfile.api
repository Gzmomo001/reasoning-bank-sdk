FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN pip install uv && uv sync --no-dev --frozen

COPY reasoning_bank/ reasoning_bank/
COPY reasoning_bank_api/ reasoning_bank_api/

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "reasoning_bank_api.app:app", "--host", "0.0.0.0", "--port", "8000"]
