# ReasoningBank Local Deployment
# Copy this file to .env and fill in the values
# Usage: cp .env.example .env && vim .env

# ---- Required ----

# LLM API key (required for induction / scaling)
LLM_API_KEY=

# ---- LLM ----

# LLM provider: openai | anthropic | vertexai | google_ai
LLM_PROVIDER=openai

# LLM model name
LLM_MODEL=gpt-4o

# Custom base URL for OpenAI-compatible APIs (leave empty for default)
LLM_API_BASE_URL=

# ---- Embedding ----

# Embedding provider: gemini | openai
EMBEDDING_PROVIDER=gemini

# Embedding model name (leave empty for provider default)
EMBEDDING_MODEL=gemini-embedding-001

# Embedding API key (falls back to LLM_API_KEY if empty)
# Required for Gemini with Google AI Studio; not needed for Vertex AI (uses ADC)
# EMBEDDING_API_KEY=

# ---- Rate Limiting ----

# Max LLM requests per minute (0 = unlimited)
LLM_RPM=0

# Max embedding requests per minute (0 = unlimited)
EMBEDDING_RPM=0

# ---- Storage ----

# Storage backend: chroma | jsonl
STORAGE=chroma

# Storage directory path (used by both chroma persistent client and jsonl)
STORAGE_PATH=./memories

# ChromaDB host (leave empty to use embedded PersistentClient, no separate DB needed)
# CHROMA_HOST=localhost

# ChromaDB port (only needed when CHROMA_HOST is set)
# CHROMA_PORT=8000

# ---- Google Gemini / Vertex AI ----

# Set to True if using Vertex AI instead of Google AI Studio
GOOGLE_GENAI_USE_VERTEXAI=False
