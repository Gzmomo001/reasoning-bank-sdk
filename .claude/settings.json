{
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "[ -d .venv ] && exit 0; ORIG=\"${PWD%/.claude/worktrees/*}\"; uv sync 2>&1; [ -f \"$ORIG/.env\" ] && [ ! -e .env ] && ln -s \"$ORIG/.env\" .env"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check . && uv run ruff format --check ."
          }
        ]
      }
    ]
  }
}
